name: Build Android APK
on: [push]
jobs:
  build:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4  # Updated to v4
      
      - [span_8](start_span)name: set up JDK 17        # Updated to 17 for modern Android compatibility
        uses: actions/setup-java@v4 # Updated to v4
        with:
          java-version: '17'
          distribution: 'temurin' # 'temurin' is recommended for GitHub Actions[span_8](end_span)

      - name: Make Gradle executable
        run: chmod +x ./gradlew
        
      - name: Build Debug APK
        run: ./gradlew assembleDebug
        
      - name: Upload APK
        uses: actions/upload-artifact@v4 # Updated to v4
        with:
          name: app-debug
          path: app/build/outputs/apk/debug/app-debug.apk
